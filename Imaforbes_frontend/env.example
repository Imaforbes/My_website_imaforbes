# Environment Variables Template
# 
# ⚠️  SECURITY WARNING: This is a template file!
# 
# 1. Copy this file to '.env'
# 2. Replace the placeholder values with your actual environment variables
# 3. NEVER commit the actual '.env' file to version control
# 4. Add '.env' to your .gitignore file

# Application Environment
VITE_APP_ENV=development
VITE_APP_NAME=IMAFORBES Portfolio
VITE_APP_VERSION=1.0.0

# API Configuration
# Development: Uses Vite proxy (handles /api -> backend on localhost:8888)
# Production: Uses direct URL
# VITE_API_BASE_URL=http://localhost:8888/api_db_portfolio  # Direct URL (if not using proxy)
# VITE_API_BASE_URL=/api_db_portfolio  # Legacy proxy URL (older setups)
# If you want to override the proxy approach, you can set a direct URL instead:
# VITE_API_BASE_URL=http://localhost:8888/Sitio_Web_imaforbes/Imaforbes_Api_backend

# Production API (uncomment for production)
# VITE_API_BASE_URL=https://www.imaforbes.com/api_db

VITE_API_TIMEOUT=10000
VITE_API_RETRIES=3

# Security Settings
VITE_SESSION_TIMEOUT=3600
VITE_MAX_LOGIN_ATTEMPTS=5
VITE_RATE_LIMIT=100

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true
VITE_ENABLE_LOGGING=true

# External Services (add your actual keys)
# VITE_GOOGLE_MAPS_KEY=your-google-maps-key
# VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
# VITE_ANALYTICS_ID=your-analytics-id

# Email Configuration
# VITE_CONTACT_EMAIL=contact@imaforbes.com
# VITE_ADMIN_EMAIL=admin@imaforbes.com

# Social Media Links
# VITE_GITHUB_URL=https://github.com/imaforbes
# VITE_LINKEDIN_URL=https://linkedin.com/in/imaforbes
# VITE_TWITTER_URL=https://twitter.com/imaforbes
