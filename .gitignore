# ========================================
# Sitio_Web_imaforbes - Global .gitignore
# Applies to both frontend and backend.
# ========================================

# --- Environment / secrets ---
.env
.env.*
!.env.example
!.env.*.example

# --- Dependencies ---
**/node_modules/
**/vendor/

# --- Builds / artifacts ---
**/dist/
**/build/
**/.next/
**/out/
**/*.log

# --- Uploads / runtime storage ---
**/uploads/*
**/storage/*
**/tmp/*
**/cache/*

# --- OS / editor ---
.DS_Store
**/.DS_Store
.vscode/
.idea/

